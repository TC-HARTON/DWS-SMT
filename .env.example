# MT5-Python Trading Dashboard - environment template
# .env にコピーして自分の値を入れる(.env はコミット禁止)

# --- MT5 ---
# 使用するMT5ターミナルの絶対パス。複数ターミナルを切り替える場合は
# このパスを書き換えて Dashboard.bat を再起動するだけでよい
# (SwitchBroker.bat でワンクリック切替も可)。
#
# 既知のターミナルパス:
#   Exness:      C:\Program Files\MetaTrader 5 EXNESS\terminal64.exe
#   IC Markets:  C:\Program Files\MetaTrader 5 IC Markets Global\terminal64.exe
MT5_TERMINAL_PATH=C:\Program Files\MetaTrader 5 EXNESS\terminal64.exe

# MT5 ログイン(保存済みログインを使う場合は3つとも空でよい)
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# mt5.initialize のタイムアウト(ms)
MT5_TIMEOUT_MS=10000

# --- LineExporter EA 出力フォルダ(SPEC 9.1 / Common 共有方式に確定) ---
LINES_DIR=C:\Users\ohuch\AppData\Roaming\MetaQuotes\Terminal\Common\Files

# --- Dash サーバー ---
DASH_HOST=127.0.0.1
DASH_PORT=8050
DASH_DEBUG=false

# --- ログレベル ---
LOG_LEVEL=INFO
