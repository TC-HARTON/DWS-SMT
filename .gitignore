# env
.env

# python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.venv/
.mypy_cache/

# logs / cache / runtime data
logs/*.log
logs/*.log.*
data/cache/*
data/lines/*
# Per-broker live trigger history — runtime state, accumulated on disk,
# broker/account-specific. Never commit (like cache/lines).
data/live_triggers/
# Per-broker discretionary-trade journal — runtime state, same class as
# live_triggers (written at order time by analyzer/journal_store.py).
data/journal/
external/forex_factory_xml/*
external/macro/*
!**/.gitkeep

# editor
.vscode/
.idea/
*.swp
.gstack/

# Dukascopy historical OHLC CSV data at the project root (Bid+Ask for 10
# symbols × 5 TFs, ~700 MB total). Used by scripts/_backtest_*.py — kept out
# of git since it is bulk external data and trivially re-downloadable.
# Underscore form = Dukascopy history (e.g. XAUUSD_2020.csv); no-underscore
# form = MT5 terminal export (e.g. XAUUSDM15.csv). The leading / + uppercase
# anchor keeps these from matching data/loss_analysis/xauusd_per_trade.csv.
/XAUUSD*.csv
/USDJPY*.csv
/EURUSD*.csv
/GBPUSD*.csv
/AUDUSD*.csv
/EURJPY*.csv
/GBPJPY*.csv
/AUDJPY*.csv
/EURGBP*.csv
/EURAUD*.csv

# Pattern-extraction per-trade ledger — 6.5 MB analysis artifact,
# regenerated by scripts/_extract_xauusd_patterns.py. Centroid + win-rate
# JSON IS committed (small + needed at runtime).
data/loss_analysis/xauusd_per_trade.csv
