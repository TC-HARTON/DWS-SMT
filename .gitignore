# env
.env

# python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.venv/
.mypy_cache/

# logs / cache / runtime data
logs/*.log
logs/*.log.*
data/cache/*
# Per-broker discretionary-trade journal — runtime state, broker/account-specific,
# append-only JSONL written at order time by analyzer/journal_store.py. Never commit.
data/journal/
external/forex_factory_xml/*
external/macro/*
external/cot/*
!**/.gitkeep

# editor
.vscode/
.idea/
*.swp
.gstack/

# tooling state (superpowers / worktrees) — never commit
.superpowers/
.claude/worktrees/

# Dukascopy / MT5 historical OHLC CSV data at the project root (~700 MB total).
# Bulk external data, trivially re-downloadable; kept out of git. Underscore form
# = Dukascopy history (e.g. XAUUSD_2020.csv); no-underscore form = MT5 terminal
# export (e.g. XAUUSDM15.csv). Leading / + uppercase anchors to the repo root only.
/XAUUSD*.csv
/USDJPY*.csv
/EURUSD*.csv
/GBPUSD*.csv
/AUDUSD*.csv
/EURJPY*.csv
/GBPJPY*.csv
/AUDJPY*.csv
/EURGBP*.csv
/EURAUD*.csv
